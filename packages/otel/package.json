{
	"name": "@better-webhook/otel",
	"version": "1.1.0",
	"description": "OpenTelemetry bridge for Better Webhook delivery observability",
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		}
	},
	"files": [
		"dist",
		"docs",
		"README.md",
		"LICENSE"
	],
	"scripts": {
		"build": "tsc --build tsconfig.json",
		"check-types": "tsc --noEmit -p tsconfig.test.json",
		"clean": "rm -rf dist .turbo tsconfig.tsbuildinfo",
		"format:check": "biome check .",
		"format:write": "biome check --write .",
		"lint": "biome lint .",
		"test": "vitest run"
	},
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/endalk200/better-webhook",
		"directory": "packages/otel"
	},
	"bugs": {
		"url": "https://github.com/endalk200/better-webhook/issues"
	},
	"homepage": "https://github.com/endalk200/better-webhook#readme",
	"publishConfig": {
		"access": "public",
		"provenance": true
	},
	"engines": {
		"node": ">=18"
	},
	"dependencies": {
		"@better-webhook/core": "workspace:*"
	},
	"devDependencies": {
		"@better-webhook/biome-config": "workspace:*",
		"@better-webhook/typescript-config": "workspace:*",
		"typescript": "6.0.3",
		"vitest": "^4.1.8"
	}
}

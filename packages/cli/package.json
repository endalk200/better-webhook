{
  "name": "@better-webhook/cli",
  "version": "2.0.0-beta.2",
  "private": true,
  "description": "Command line interface for better-webhook",
  "type": "module",
  "bin": {
    "bw": "npm/bin/bw.js"
  },
  "scripts": {
    "build": "go build -o bin/bw ./cmd/bw",
    "cli:dev": "sh -c 'if [ \"$1\" = \"--\" ]; then shift; fi; go run ./cmd/bw \"$@\"' --",
    "cli:built": "sh -c 'if [ \"$1\" = \"--\" ]; then shift; fi; ./bin/bw \"$@\"' --",
    "clean": "rm -rf bin dist .turbo",
    "check-types": "go vet ./...",
    "format:check": "gofumpt -l . && test -z \"$(gofumpt -l .)\"",
    "format:write": "gofumpt -w . && goimports -w .",
    "lint": "golangci-lint run ./...",
    "test": "go test ./... && pnpm run build && node --test test/*.test.js",
    "release:check": "node scripts/validate-release.mjs",
    "release:package-npm": "node scripts/package-npm.mjs"
  },
  "files": [
    "npm",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "webhook",
    "cli",
    "better-webhook"
  ],
  "license": "MIT",
  "author": "Endalk <endalk200>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/endalk200/better-webhook.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/endalk200/better-webhook/issues"
  },
  "homepage": "https://github.com/endalk200/better-webhook#readme",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "engines": {
    "node": ">=18"
  }
}

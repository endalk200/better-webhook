{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.16.0/.schema/devbox.schema.json",
  "packages": [
    "just@latest",
    "trivy@0.69.0",
    "nodejs@24.12.0",
    "goreleaser@latest",
    "golangci-lint@2.9.0",
    "pnpm@10.28.0",
    "go@1.26.0",
    "gofumpt@latest",
    "goimports@latest"
  ],
  "env": {
    "TRIVY_CACHE_DIR": "$PWD/.cache/trivy"
  },
  "shell": {
    "init_hook": ["mkdir -p .cache/trivy"],
    "scripts": {}
  }
}

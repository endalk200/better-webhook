{
	"$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.17.2/.schema/devbox.schema.json",
	"packages": [
		"just@1.51.0",
		"trivy@0.69.3",
		"nodejs@24.12.0",
		"goreleaser@2.15.4",
		"golangci-lint@2.12.2",
		"bun@1.3.13",
		"go@1.26.2",
		"gofumpt@0.10.0",
		"gotools@0.44.0"
	],
	"env": {
		"TRIVY_CACHE_DIR": "$PWD/.cache/trivy"
	},
	"shell": {
		"init_hook": ["mkdir -p .cache/trivy"],
		"scripts": {}
	}
}

{
	"extends": "@better-webhook/typescript-config/base.json",
	"compilerOptions": {
		"allowJs": true,
		"composite": false,
		"declaration": false,
		"declarationMap": false,
		"incremental": true,
		"jsx": "preserve",
		"noEmit": true,
		"plugins": [{ "name": "next" }],
		"tsBuildInfoFile": "tsconfig.tsbuildinfo",
		"types": ["node"]
	},
	"include": [
		"next-env.d.ts",
		"app/**/*.ts",
		"scripts/**/*.ts",
		"src/**/*.ts",
		".next/types/**/*.ts"
	],
	"exclude": ["node_modules"]
}

{
  "name": "@better-webhook/example-nextjs",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --hostname 127.0.0.1 --port ${PORT:-3001}",
    "build": "next build",
    "check-types": "tsc --noEmit",
    "lint": "eslint .",
    "test": "echo \"No automated behavioral tests for this Example Application\"",
    "format:check": "prettier --check \"app/**/*.ts\" \"src/**/*.ts\" \"scripts/**/*.ts\" README.md next.config.mjs",
    "format:write": "prettier --write \"app/**/*.ts\" \"src/**/*.ts\" \"scripts/**/*.ts\" README.md next.config.mjs",
    "send:stripe:checkout": "tsx scripts/stripe/send.ts checkout",
    "send:stripe:invoice": "tsx scripts/stripe/send.ts invoice",
    "send:stripe:unknown": "tsx scripts/stripe/send.ts unknown",
    "send:stripe:duplicate": "tsx scripts/stripe/send.ts duplicate",
    "send:stripe:replay": "tsx scripts/stripe/send.ts replay",
    "send:stripe:ignored": "tsx scripts/stripe/send.ts ignored",
    "send:stripe:failure": "tsx scripts/stripe/send.ts failure"
  },
  "dependencies": {
    "@better-webhook/core": "workspace:*",
    "@better-webhook/nextjs": "workspace:*",
    "@better-webhook/otel": "workspace:*",
    "@better-webhook/stripe": "workspace:*",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.218.0",
    "@opentelemetry/resources": "^2.2.0",
    "@opentelemetry/sdk-node": "^0.218.0",
    "next": "^16.0.7",
    "react": "^19.2.1",
    "react-dom": "^19.2.1"
  },
  "devDependencies": {
    "@better-webhook/eslint-config": "workspace:*",
    "@better-webhook/typescript-config": "workspace:*",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}

{
  "name": "@better-webhook/example-express-stripe",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx src/server.ts",
    "build": "tsc --build tsconfig.json",
    "check-types": "tsc --noEmit",
    "lint": "eslint .",
    "test": "echo \"No automated behavioral tests for this Example Application\"",
    "format:check": "prettier --check \"src/**/*.ts\" README.md",
    "format:write": "prettier --write \"src/**/*.ts\" README.md",
    "send:checkout": "tsx src/send.ts checkout",
    "send:invoice": "tsx src/send.ts invoice",
    "send:unknown": "tsx src/send.ts unknown",
    "send:duplicate": "tsx src/send.ts duplicate",
    "send:replay": "tsx src/send.ts replay",
    "send:ignored": "tsx src/send.ts ignored",
    "send:failure": "tsx src/send.ts failure"
  },
  "dependencies": {
    "@better-webhook/core": "workspace:*",
    "@better-webhook/express": "workspace:*",
    "@better-webhook/otel": "workspace:*",
    "@better-webhook/stripe": "workspace:*",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.218.0",
    "@opentelemetry/resources": "^2.2.0",
    "@opentelemetry/sdk-node": "^0.218.0",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@better-webhook/eslint-config": "workspace:*",
    "@better-webhook/typescript-config": "workspace:*",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.1",
    "eslint": "^9.39.4",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}

{
  "name": "@better-webhook/example-express",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx src/server.ts",
    "build": "tsc --build tsconfig.json",
    "check-types": "tsc --noEmit",
    "lint": "eslint .",
    "test": "echo \"No automated behavioral tests for this Example Application\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"scripts/**/*.ts\" README.md",
    "format:write": "prettier --write \"src/**/*.ts\" \"scripts/**/*.ts\" README.md",
    "send:stripe:checkout": "tsx scripts/stripe/send.ts checkout",
    "send:stripe:invoice": "tsx scripts/stripe/send.ts invoice",
    "send:stripe:unknown": "tsx scripts/stripe/send.ts unknown",
    "send:stripe:duplicate": "tsx scripts/stripe/send.ts duplicate",
    "send:stripe:replay": "tsx scripts/stripe/send.ts replay",
    "send:stripe:ignored": "tsx scripts/stripe/send.ts ignored",
    "send:stripe:failure": "tsx scripts/stripe/send.ts failure",
    "send:github:pull-request": "tsx scripts/github/send.ts pull-request",
    "send:github:issue-comment": "tsx scripts/github/send.ts issue-comment",
    "send:github:check-run": "tsx scripts/github/send.ts check-run",
    "send:github:duplicate": "tsx scripts/github/send.ts duplicate",
    "send:github:replay": "tsx scripts/github/send.ts replay",
    "send:github:ignored": "tsx scripts/github/send.ts ignored",
    "send:github:unknown": "tsx scripts/github/send.ts unknown",
    "send:github:failure": "tsx scripts/github/send.ts failure"
  },
  "dependencies": {
    "@better-webhook/core": "workspace:*",
    "@better-webhook/express": "workspace:*",
    "@better-webhook/github": "workspace:*",
    "@better-webhook/otel": "workspace:*",
    "@better-webhook/stripe": "workspace:*",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.218.0",
    "@opentelemetry/resources": "^2.2.0",
    "@opentelemetry/sdk-node": "^0.218.0",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@better-webhook/eslint-config": "workspace:*",
    "@better-webhook/typescript-config": "workspace:*",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.1",
    "eslint": "^9.39.4",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}

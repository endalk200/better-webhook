{
	"name": "better-webhook",
	"devDependencies": {
		"@biomejs/biome": "2.3.8",
		"@changesets/cli": "^2.27.9",
		"turbo": "^2.9.14",
		"typescript": "6.0.3",
		"vitest": "^4.0.16"
	},
	"engines": {
		"node": ">=18"
	},
	"packageManager": "bun@1.3.3",
	"private": true,
	"scripts": {
		"lint": "biome lint . && turbo run lint",
		"check-types": "turbo run check-types",
		"dev": "turbo run dev",
		"build": "turbo run build",
		"cli:dev": "bun --filter @better-webhook/cli run cli:dev",
		"cli:build": "bun --filter @better-webhook/cli run build",
		"cli:built": "bun --filter @better-webhook/cli run cli:built",
		"test": "turbo run test",
		"changeset": "changeset",
		"changeset:status": "changeset status",
		"changeset:version": "changeset version && bun install --lockfile-only",
		"release": "turbo run build && changeset publish",
		"release:publish": "changeset publish",
		"prerelease": "bun run build && bun run check-types && bun run lint",
		"clean": "turbo run clean",
		"format:check": "biome check . && turbo run format:check",
		"format:write": "biome check --write . && turbo run format:write"
	},
	"workspaces": [
		"packages/*",
		"apps/examples/*"
	],
	"overrides": {
		"ajv@6.12.6": "6.14.0",
		"brace-expansion@1.1.12": "1.1.13",
		"brace-expansion@2.0.2": "2.0.3",
		"flatted@3.3.3": "3.4.2",
		"js-yaml@3.14.1": "3.14.2",
		"js-yaml@4.1.0": "4.1.1",
		"minimatch@3.1.2": "3.1.4",
		"minimatch@9.0.5": "9.0.7",
		"postcss@8.4.31": "8.5.10",
		"postcss@8.5.6": "8.5.10"
	}
}

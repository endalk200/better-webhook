{
  "name": "better-webhook",
  "private": true,
  "scripts": {
    "lint": "turbo run lint",
    "check-types": "turbo run check-types",
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "changeset": "changeset",
    "changeset:status": "changeset status",
    "changeset:version": "changeset version && pnpm install --lockfile-only",
    "release": "turbo run build && changeset publish",
    "release:publish": "changeset publish",
    "prerelease": "pnpm build && pnpm check-types && pnpm lint",
    "clean": "turbo run clean",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,mdx,md,json,yml,yaml}\" --cache",
    "format:write": "prettier --write \"**/*.{ts,tsx,js,jsx,mdx,md,json,yml,yaml}\" --cache"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.9",
    "prettier": "^3.6.2",
    "turbo": "^2.8.13",
    "typescript": "^5.6.3",
    "vitest": "^4.0.16"
  },
  "pnpm": {
    "overrides": {
      "@isaacs/brace-expansion@5.0.0": "5.0.1",
      "@modelcontextprotocol/sdk@1.25.1": "1.26.0",
      "hono": "4.12.0",
      "minimatch@10.1.1": "10.2.1",
      "qs@6.13.0": "6.14.1",
      "qs@6.14.0": "6.14.1"
    },
    "onlyBuiltDependencies": [
      "@nestjs/core"
    ]
  },
  "packageManager": "pnpm@10.28.0",
  "engines": {
    "node": ">=18"
  }
}

{
  "name": "better-webhook",
  "private": true,
  "scripts": {
    "lint": "turbo run lint",
    "check-types": "turbo run check-types",
    "dev": "turbo run dev",
    "build": "turbo run build",
    "cli:dev": "pnpm --filter @better-webhook/cli run cli:dev",
    "cli:build": "pnpm --filter @better-webhook/cli run build",
    "cli:built": "pnpm --filter @better-webhook/cli run cli:built",
    "test": "turbo run test",
    "changeset": "changeset",
    "changeset:status": "changeset status",
    "changeset:version": "changeset version && pnpm install --lockfile-only",
    "release": "turbo run build && changeset publish",
    "release:publish": "changeset publish",
    "prerelease": "pnpm build && pnpm check-types && pnpm lint",
    "clean": "turbo run clean",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,mdx,md,json,yml,yaml}\" --cache && turbo run format:check",
    "format:write": "prettier --write \"**/*.{ts,tsx,js,jsx,mdx,md,json,yml,yaml}\" --cache && turbo run format:write"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.9",
    "prettier": "^3.6.2",
    "turbo": "^2.9.3",
    "typescript": "^5.6.3",
    "vitest": "^4.0.16"
  },
  "pnpm": {
    "overrides": {
      "@isaacs/brace-expansion@5.0.0": "5.0.1",
      "@modelcontextprotocol/sdk@1.25.1": "1.26.0",
      "hono": "4.12.4",
      "minimatch@10.1.1": "10.2.1",
      "multer@2.0.2": "2.1.1",
      "path-to-regexp@0.1.12": "0.1.13",
      "path-to-regexp@8.3.0": "8.4.0",
      "picomatch@2.3.1": "2.3.2",
      "picomatch@4.0.2": "4.0.4",
      "picomatch@4.0.3": "4.0.4",
      "protobufjs@7.5.4": "7.5.5",
      "qs@6.13.0": "6.14.1",
      "qs@6.14.0": "6.14.1",
      "rollup@4.50.1": "4.59.0",
      "vite@7.3.0": "7.3.2"
    },
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@prisma/client",
      "@prisma/engines",
      "prisma"
    ]
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=18"
  }
}
